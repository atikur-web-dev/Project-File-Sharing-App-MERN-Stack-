<mxfile host="app.diagrams.net">
  <diagram name="Registration Swimlane" id="register-swimlane">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- Swimlane 1: User -->
        <mxCell id="lane-user" value="USER" style="swimlane;startSize=40;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="180" height="820" as="geometry"/>
        </mxCell>
        
        <!-- Swimlane 2: Frontend -->
        <mxCell id="lane-frontend" value="FRONTEND" style="swimlane;startSize=40;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="220" y="40" width="320" height="820" as="geometry"/>
        </mxCell>
        
        <!-- Swimlane 3: Backend -->
        <mxCell id="lane-backend" value="BACKEND" style="swimlane;startSize=40;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="540" y="40" width="380" height="820" as="geometry"/>
        </mxCell>
        
        <!-- Swimlane 4: Database -->
        <mxCell id="lane-database" value="DATABASE &amp; EMAIL" style="swimlane;startSize=40;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="920" y="40" width="220" height="820" as="geometry"/>
        </mxCell>
        
        <!-- Swimlane 5: Context -->
        <mxCell id="lane-context" value="CONTEXT" style="swimlane;startSize=40;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1140" y="40" width="220" height="820" as="geometry"/>
        </mxCell>

        <!-- USER ACTIONS -->
        <mxCell id="user-open" value="Open Register Page" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="140" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="user-fill" value="Fill Form Data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="140" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="user-click" value="Click Register" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- USER ARROWS -->
        <mxCell id="user-arrow-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1565C0;" edge="1" parent="1" source="user-open" target="user-fill">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="user-arrow-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1565C0;" edge="1" parent="1" source="user-fill" target="user-click">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- FRONTEND ACTIONS -->
        <mxCell id="fe-render" value="RegisterPage.tsx Renders" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="250" y="120" width="160" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="fe-form" value="RegisterForm.tsx Display" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="250" y="220" width="160" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="fe-validate" value="Client Side Validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="250" y="340" width="160" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="fe-hook" value="Call useAuth().register()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="250" y="450" width="180" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="fe-api" value="Call registerApi()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="250" y="550" width="160" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="fe-axios" value="Axios POST Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="250" y="650" width="160" height="40" as="geometry"/>
        </mxCell>

        <!-- FRONTEND ARROWS -->
        <mxCell id="fe-arrow-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2E7D32;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="fe-render" target="fe-form">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="fe-arrow-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="fe-form" target="fe-validate">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="fe-arrow-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="fe-validate" target="fe-hook">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="fe-arrow-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="fe-hook" target="fe-api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="fe-arrow-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="fe-api" target="fe-axios">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- BACKEND ACTIONS -->
        <mxCell id="be-server" value="server.ts Receives Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="570" y="120" width="180" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="be-middleware" value="Global Middlewares Execute" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="570" y="230" width="180" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="be-route" value="Route to auth.controller.ts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="570" y="340" width="190" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="be-controller" value="register() Controller Called" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="570" y="450" width="180" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="be-service" value="Call registerService()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="570" y="560" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- BACKEND ARROWS -->
        <mxCell id="be-arrow-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="be-server" target="be-middleware">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="be-arrow-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="be-middleware" target="be-route">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="be-arrow-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="be-route" target="be-controller">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="be-arrow-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="be-controller" target="be-service">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DATABASE ACTIONS -->
        <mxCell id="db-validate" value="Zod Validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="940" y="120" width="150" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="db-check" value="Check Existing User" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="940" y="230" width="150" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="db-create" value="User.create()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="940" y="340" width="150" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="db-hash" value="bcrypt.hash() Password" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="940" y="450" width="150" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="db-save" value="Save to MongoDB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="940" y="560" width="150" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="db-email" value="Send Email via Resend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="940" y="650" width="150" height="40" as="geometry"/>
        </mxCell>

        <!-- DATABASE ARROWS -->
        <mxCell id="db-arrow-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6A1B9A;" edge="1" parent="1" source="db-validate" target="db-check">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="db-arrow-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6A1B9A;" edge="1" parent="1" source="db-check" target="db-create">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="db-arrow-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6A1B9A;" edge="1" parent="1" source="db-create" target="db-hash">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="db-arrow-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6A1B9A;" edge="1" parent="1" source="db-hash" target="db-save">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="db-arrow-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6A1B9A;" edge="1" parent="1" source="db-save" target="db-email">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CONTEXT ACTIONS -->
        <mxCell id="ctx-response" value="Return User Data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="1170" y="120" width="160" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="ctx-set" value="AuthContext.setUser()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="1170" y="230" width="160" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="ctx-store" value="Store in LocalStorage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="1170" y="340" width="160" height="40" as="geometry"/>
        </mxCell>
        
        <mxCell id="ctx-redirect" value="Redirect to /login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="1170" y="450" width="160" height="40" as="geometry"/>
        </mxCell>

        <!-- CONTEXT ARROWS -->
        <mxCell id="ctx-arrow-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="ctx-response" target="ctx-set">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="ctx-arrow-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="ctx-set" target="ctx-store">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="ctx-arrow-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="ctx-store" target="ctx-redirect">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CROSS LANE ARROWS -->
        <!-- User to Frontend -->
        <mxCell id="cross-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1565C0;dashed=1;" edge="1" parent="1" source="user-open" target="fe-render">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="cross-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1565C0;dashed=1;" edge="1" parent="1" source="user-fill" target="fe-form">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="cross-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1565C0;dashed=1;" edge="1" parent="1" source="user-click" target="fe-validate">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Frontend to Backend -->
        <mxCell id="cross-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D32F2F;dashed=1;" edge="1" parent="1" source="fe-axios" target="be-server">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="410" y="670"/>
              <mxPoint x="500" y="670"/>
              <mxPoint x="500" y="140"/>
              <mxPoint x="570" y="140"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Backend to Database -->
        <mxCell id="cross-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#E65100;dashed=1;" edge="1" parent="1" source="be-service" target="db-validate">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="580"/>
              <mxPoint x="880" y="580"/>
              <mxPoint x="880" y="140"/>
              <mxPoint x="940" y="140"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Database to Backend Response -->
        <mxCell id="cross-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6A1B9A;dashed=1;" edge="1" parent="1" source="db-email" target="ctx-response">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1015" y="690"/>
              <mxPoint x="1090" y="690"/>
              <mxPoint x="1090" y="140"/>
              <mxPoint x="1170" y="140"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Context to Frontend Redirect -->
        <mxCell id="cross-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#E65100;dashed=1;" edge="1" parent="1" source="ctx-redirect" target="fe-render">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1250" y="490"/>
              <mxPoint x="1300" y="490"/>
              <mxPoint x="1300" y="780"/>
              <mxPoint x="330" y="780"/>
              <mxPoint x="330" y="160"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Cross Labels -->
        <mxCell id="label-http" value="HTTP" style="text;html=1;strokeColor=none;fillColor=#FFCDD2;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="470" y="655" width="50" height="25" as="geometry"/>
        </mxCell>
        
        <mxCell id="label-service" value="SERVICE" style="text;html=1;strokeColor=none;fillColor=#FFCC80;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="850" y="560" width="60" height="25" as="geometry"/>
        </mxCell>
        
        <mxCell id="label-response" value="RESPONSE" style="text;html=1;strokeColor=none;fillColor=#CE93D8;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1080" y="675" width="70" height="25" as="geometry"/>
        </mxCell>
        
        <mxCell id="label-redirect" value="REDIRECT" style="text;html=1;strokeColor=none;fillColor=#FFCC80;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1240" y="760" width="60" height="25" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
